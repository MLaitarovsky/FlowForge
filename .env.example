# ── Database ──────────────────────────────────────────────────────────────────
# Local:      postgresql://flowforge:flowforge@localhost:5434/flowforge
# Production: provided by Railway PostgreSQL plugin (copy from Railway dashboard)
DATABASE_URL="postgresql://flowforge:flowforge@localhost:5434/flowforge"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Local:      http://localhost:3000
# Production: your Vercel URL, e.g. https://flowforge.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Generate: openssl rand -hex 32
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars-here"

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Encryption (BYOK key storage) ────────────────────────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_SECRET="your-32-byte-hex-encryption-secret-here"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:      redis://localhost:6381
# Production: provided by Railway Redis plugin (copy from Railway dashboard)
REDIS_URL="redis://localhost:6381"

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Local:      http://localhost:8020
# Production: your Railway ChromaDB service URL
CHROMA_URL="http://localhost:8020"

# ── Public app URL ────────────────────────────────────────────────────────────
# Used for Open Graph metadataBase. Set to your production domain.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
